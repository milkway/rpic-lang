---
// Interactive ease explorer — the "graph view" of GSAP's ease visualiser, for
// the ease names you pass to rpic's `ease "…"` clause. GSAP-powered (client
// side): it samples the real ease function with `gsap.parseEase` to plot the
// curve, then animates a marker along it with a live progress/value readout.
// Unlike the pic examples this is not authored in pic — it's a playground for
// the vocabulary the animate layer accepts.
---

<div
  class="ease-viz not-prose mb-6 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/40 p-4"
>
  <div class="flex flex-wrap items-end gap-3 mb-4">
    <label class="text-xs font-medium text-slate-600 dark:text-slate-300">
      Ease
      <select
        class="ez-family mt-1 block rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 text-sm px-2 py-1.5"
      >
        <optgroup label="Standard">
          <option value="none">none</option>
          <option value="power1">power1</option>
          <option value="power2" selected>power2</option>
          <option value="power3">power3</option>
          <option value="power4">power4</option>
          <option value="back">back</option>
          <option value="bounce">bounce</option>
          <option value="circ">circ</option>
          <option value="elastic">elastic</option>
          <option value="expo">expo</option>
          <option value="sine">sine</option>
          <option value="steps">steps</option>
        </optgroup>
        <optgroup label="EasePack">
          <option value="rough">rough</option>
          <option value="slow">slow</option>
          <option value="expoScale">expoScale</option>
        </optgroup>
        <optgroup label="Extra Eases">
          <option value="customEase">CustomEase</option>
          <option value="customBounce">CustomBounce</option>
          <option value="customWiggle">CustomWiggle</option>
        </optgroup>
      </select>
    </label>
    <label class="text-xs font-medium text-slate-600 dark:text-slate-300">
      Variant
      <select
        class="ez-variant mt-1 block rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 text-sm px-2 py-1.5"
      >
        <option value="in">in</option>
        <option value="out" selected>out</option>
        <option value="inOut">inOut</option>
      </select>
    </label>
    <button
      class="ez-play rounded-md bg-emerald-700 hover:bg-emerald-600 text-white font-semibold text-sm px-4 py-2"
      type="button">▶ Preview</button>
    <code class="ez-name ml-auto text-[13px] font-mono text-emerald-800 dark:text-emerald-300"></code>
  </div>

  <div class="grid sm:grid-cols-[1fr_auto] gap-4 items-center">
    <svg class="ez-svg w-full max-w-md" viewBox="-12 -200 564 900" style="overflow: visible">
      <!-- grid -->
      <g class="stroke-slate-200 dark:stroke-slate-700" stroke-width="1" fill="none">
        {[0, 1, 2, 3, 4, 5].map((i) => (
          <>
            <line x1={i * 100} y1="0" x2={i * 100} y2="500" />
            <line x1="0" y1={i * 100} x2="500" y2={i * 100} />
          </>
        ))}
      </g>
      <!-- unit box + linear reference -->
      <rect x="0" y="0" width="500" height="500" class="fill-none stroke-slate-300 dark:stroke-slate-600" stroke-width="1.5" />
      <line x1="0" y1="500" x2="500" y2="0" class="stroke-slate-300 dark:stroke-slate-600" stroke-width="1.5" stroke-dasharray="6 6" />
      <!-- the ease curve -->
      <path class="ez-curve fill-none stroke-[#0ae448]" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
      <!-- sweep + markers -->
      <line class="ez-sweep stroke-slate-400 dark:stroke-slate-500" x1="0" y1="500" x2="0" y2="500" stroke-width="1.5" style="opacity:0" />
      <circle class="ez-dot fill-[#0ae448]" cx="0" cy="500" r="12" style="opacity:0" />
    </svg>
    <div class="text-sm font-mono text-slate-600 dark:text-slate-300 space-y-1 min-w-[9rem]">
      <div>progress: <span class="ez-progress text-slate-900 dark:text-white">0.00</span></div>
      <div>value: <span class="ez-value text-slate-900 dark:text-white">0.00</span></div>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  import { EasePack, RoughEase, SlowMo, ExpoScaleEase } from 'gsap/EasePack';
  import { CustomEase } from 'gsap/CustomEase';
  import { CustomBounce } from 'gsap/CustomBounce';
  import { CustomWiggle } from 'gsap/CustomWiggle';

  gsap.registerPlugin(
    MotionPathPlugin,
    EasePack,
    RoughEase,
    SlowMo,
    ExpoScaleEase,
    CustomEase,
    CustomBounce,
    CustomWiggle
  );

  const W = 500;
  const H = 500;

  // Eases whose `.in/.out/.inOut` variants are meaningful.
  const HAS_VARIANT = new Set([
    'power1', 'power2', 'power3', 'power4', 'back', 'bounce', 'circ', 'elastic', 'expo', 'sine',
  ]);

  // Turn the two selects into a GSAP ease string. The plugin/custom eases take
  // representative parameters (there's no single "right" value — this is a demo).
  function easeString(family: string, variant: string): string {
    switch (family) {
      case 'none':
        return 'none';
      case 'steps':
        return 'steps(6)';
      case 'rough':
        return 'rough({ strength: 2, points: 20, taper: "both", randomize: true, clamp: false })';
      case 'slow':
        return 'slow(0.7, 0.7, false)';
      case 'expoScale':
        return 'expoScale(0.5, 7)';
      case 'customWiggle':
        return 'wiggle(6)';
      case 'customBounce':
        return 'ezCustomBounce';
      case 'customEase':
        return 'ezCustomEase';
      default:
        return `${family}.${variant}`;
    }
  }

  // A human-readable label of what you'd pass at runtime (the create-based
  // eases are registered by a name you choose).
  function easeLabel(family: string, variant: string): string {
    if (family === 'customBounce') return 'CustomBounce.create("myBounce", { strength: 0.6 })';
    if (family === 'customEase') return 'CustomEase.create("myEase", "M0,0 C0.3,0 0.3,1 1,1")';
    return `ease "${easeString(family, variant)}"`;
  }

  // Pre-create the named custom eases once (so parseEase can find them).
  // CustomBounce depends on CustomEase; either can fail if the plugin registry
  // didn't wire up — never let that crash the whole widget.
  try {
    CustomEase.create('ezCustomEase', 'M0,0 C0.3,0 0.3,1 1,1');
  } catch { /* CustomEase unavailable */ }
  try {
    CustomBounce.create('ezCustomBounce', { strength: 0.6, squash: 2 });
  } catch { /* CustomBounce unavailable */ }

  function build(root: HTMLElement) {
    const familySel = root.querySelector('.ez-family') as HTMLSelectElement;
    const variantSel = root.querySelector('.ez-variant') as HTMLSelectElement;
    const nameEl = root.querySelector('.ez-name') as HTMLElement;
    const curveEl = root.querySelector('.ez-curve') as SVGPathElement;
    const dotEl = root.querySelector('.ez-dot') as SVGCircleElement;
    const sweepEl = root.querySelector('.ez-sweep') as SVGLineElement;
    const progEl = root.querySelector('.ez-progress') as HTMLElement;
    const valEl = root.querySelector('.ez-value') as HTMLElement;
    let tween: gsap.core.Tween | null = null;

    function currentEase(): ((p: number) => number) | null {
      const name = easeString(familySel.value, variantSel.value);
      try {
        const fn = gsap.parseEase(name);
        return typeof fn === 'function' ? (fn as (p: number) => number) : null;
      } catch {
        return null;
      }
    }

    function plot() {
      variantSel.disabled = !HAS_VARIANT.has(familySel.value);
      const ease = currentEase();
      const label = easeLabel(familySel.value, variantSel.value);
      if (!ease) {
        // plugin not registered / unavailable in this build — say so instead of
        // drawing a blank graph
        nameEl.textContent = `${label} — register the GSAP plugin to preview`;
        curveEl.setAttribute('d', '');
        gsap.set([dotEl, sweepEl], { opacity: 0 });
        progEl.textContent = '—';
        valEl.textContent = '—';
        return;
      }
      nameEl.textContent = label;
      const n = 240;
      let d = '';
      for (let i = 0; i <= n; i++) {
        const t = i / n;
        const v = ease(t);
        const x = t * W;
        const y = (1 - v) * H; // value up
        d += (i === 0 ? 'M' : 'L') + x.toFixed(2) + ',' + y.toFixed(2) + ' ';
      }
      curveEl.setAttribute('d', d.trim());
    }

    function preview() {
      const ease = currentEase();
      if (!ease) return;
      tween?.kill();
      gsap.set([dotEl, sweepEl], { opacity: 1 });
      const proxy = { p: 0 };
      tween = gsap.to(proxy, {
        p: 1,
        duration: 1.6,
        ease: 'none', // progress sweeps linearly; the curve supplies the value
        onUpdate() {
          const p = proxy.p;
          const v = ease(p);
          progEl.textContent = p.toFixed(2);
          valEl.textContent = v.toFixed(2);
          const x = p * W;
          const y = (1 - v) * H;
          dotEl.setAttribute('cx', String(x));
          dotEl.setAttribute('cy', String(y));
          sweepEl.setAttribute('x1', String(x));
          sweepEl.setAttribute('x2', String(x));
          sweepEl.setAttribute('y1', '0');
          sweepEl.setAttribute('y2', String(H));
        },
      });
    }

    familySel.addEventListener('change', () => {
      plot();
      preview();
    });
    variantSel.addEventListener('change', () => {
      plot();
      preview();
    });
    (root.querySelector('.ez-play') as HTMLButtonElement).addEventListener('click', preview);
    plot();
  }

  document.querySelectorAll<HTMLElement>('.ease-viz').forEach(build);
</script>
