---
// Pic-driven ease explorer. Every (family, variant) is compiled at build time
// by rpic itself (curve plotted from the ease's formula; a value marker rides
// `move` with the GSAP ease). The selectors just swap between the pre-rendered
// bundles and re-run the animation — no client-side compiler.
import { renderPicBundle } from '../lib/rpic';
import { easePic, easeName, FAMILIES, VARIANT_FAMILIES, VARIANTS } from '../lib/ease-pic';
import { createHighlighter } from 'shiki';
import grammar from '../../../tools/highlight/rpic.tmLanguage.json';
import forestLight from '../../../tools/highlight/themes/rpic-forest-light.json';
import forestDark from '../../../tools/highlight/themes/rpic-forest-dark.json';

// Highlight the pic with the same Shiki grammar + rpic-forest themes the rest
// of the site uses; reuse the site's `.astro-code` styling (padding, border,
// dark-mode CSS-var switch) by renaming Shiki's `shiki` class to it.
const hl = await createHighlighter({
  langs: [grammar as any],
  themes: [forestLight as any, forestDark as any],
});
const highlight = (src: string) =>
  hl
    .codeToHtml(src, {
      lang: 'rpic',
      themes: { light: 'rpic-forest-light', dark: 'rpic-forest-dark' },
    })
    .replace('class="shiki', 'class="astro-code shiki');

type Bundle = { svg: string; animations: any[]; src: string; code: string };
const bundles: Record<string, Bundle> = {};
for (const family of FAMILIES) {
  const variants = family === 'none' ? (['out'] as const) : VARIANTS;
  for (const v of variants) {
    const src = easePic(family, v).trim();
    const b = renderPicBundle(src);
    bundles[family === 'none' ? 'none' : easeName(family, v)] = {
      svg: b.svg,
      animations: b.animations,
      src,
      code: highlight(src),
    };
  }
}
const variantFamilies = new Set(VARIANT_FAMILIES);
---

<div
  class="ease-viz not-prose mb-6 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/40 p-4"
  data-bundles={JSON.stringify(bundles)}
  data-variant-families={JSON.stringify([...variantFamilies])}
>
  <div class="flex flex-wrap items-end gap-3 mb-4">
    <label class="text-xs font-medium text-slate-600 dark:text-slate-300">
      Ease
      <select
        class="ez-family mt-1 block h-9 rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 text-sm px-2"
      >
        {FAMILIES.map((f) => (
          <option value={f} selected={f === 'elastic'}>{f}</option>
        ))}
      </select>
    </label>
    <label class="text-xs font-medium text-slate-600 dark:text-slate-300">
      Variant
      <select
        class="ez-variant mt-1 block h-9 rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 text-sm px-2"
      >
        {VARIANTS.map((v) => (
          <option value={v} selected={v === 'out'}>{v}</option>
        ))}
      </select>
    </label>
    <button
      class="ez-play inline-flex items-center h-9 rounded-md bg-emerald-700 hover:bg-emerald-600 text-white font-semibold text-sm px-4"
      type="button">▶ Replay</button>
    <code class="ez-name ml-auto text-[13px] font-mono text-emerald-800 dark:text-emerald-300"></code>
  </div>
  <div class="ez-stage grid place-items-center p-2 mb-4 [&_svg]:max-w-sm [&_svg]:w-full [&_svg]:h-auto [&_svg]:overflow-visible"></div>
  <div class="relative min-w-0 [&_pre]:mb-0">
    <button
      class="ez-copy absolute top-2 right-2 z-10 text-[11px] font-semibold rounded-md border border-slate-300 dark:border-slate-600 bg-white/90 dark:bg-slate-800/90 text-slate-600 dark:text-slate-300 px-2 py-1 hover:text-emerald-800 dark:hover:text-emerald-300"
      type="button">Copy</button>
    <div class="ez-code"></div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function build(root: HTMLElement) {
    const bundles = JSON.parse(root.dataset.bundles || '{}');
    const variantFamilies = new Set(JSON.parse(root.dataset.variantFamilies || '[]'));
    const familySel = root.querySelector('.ez-family') as HTMLSelectElement;
    const variantSel = root.querySelector('.ez-variant') as HTMLSelectElement;
    const nameEl = root.querySelector('.ez-name') as HTMLElement;
    const stage = root.querySelector('.ez-stage') as HTMLElement;
    const codeEl = root.querySelector('.ez-code') as HTMLElement;
    const copyBtn = root.querySelector('.ez-copy') as HTMLButtonElement;
    let tween: gsap.core.Tween | null = null;
    let currentSrc = '';

    function key(): string {
      return familySel.value === 'none' ? 'none' : `${familySel.value}.${variantSel.value}`;
    }

    function show() {
      variantSel.disabled = !variantFamilies.has(familySel.value);
      const bundle = bundles[key()];
      if (!bundle) return;
      tween?.kill();
      stage.innerHTML = bundle.svg;
      codeEl.innerHTML = bundle.code; // the highlighted pic that produced this panel
      currentSrc = bundle.src;
      // rpic marks the value marker as the `move` animation's target (`id`) and
      // the axis it climbs as its `path`; ride the pic-supplied ease up it.
      const a = bundle.animations.find((x: any) => x.effect === 'move');
      nameEl.textContent = a ? `ease "${a.ease}"` : '';
      if (!a) return;
      // `a.id`/`a.path` are the `<g id="sN">` groups; the marker and axis are
      // the `<circle>`/`<line>` inside them.
      const dot = stage.querySelector(`[id="${a.id}"] circle`) as SVGCircleElement | null;
      const track = stage.querySelector(`[id="${a.path}"] line`) as SVGLineElement | null;
      if (!dot || !track) return;
      const y1 = parseFloat(track.getAttribute('y1') || '0');
      const y2 = parseFloat(track.getAttribute('y2') || '0');
      // The marker climbs the axis once with the ease, tracing the curve's
      // value, and settles at the top (value 1) — ▶ Replay runs it again.
      tween = gsap.fromTo(
        dot,
        { attr: { cy: y1 } },
        { attr: { cy: y2 }, duration: a.duration || 1.6, ease: a.ease || 'none' }
      );
    }

    familySel.addEventListener('change', show);
    variantSel.addEventListener('change', show);
    (root.querySelector('.ez-play') as HTMLButtonElement).addEventListener('click', show);
    copyBtn.addEventListener('click', () => {
      navigator.clipboard?.writeText(currentSrc).then(() => {
        const prev = copyBtn.textContent;
        copyBtn.textContent = 'Copied';
        setTimeout(() => (copyBtn.textContent = prev), 1200);
      });
    });
    show();
  }

  document.querySelectorAll<HTMLElement>('.ease-viz').forEach(build);
</script>
