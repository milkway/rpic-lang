---
// Live-animated example: the pic source beside the SVG, with the animate
// manifest driving a real GSAP timeline in the page — plus a replay button.
// Effects mirror the @strategicprojects/rpic web player (fade/pop/draw).
import { Code } from 'astro:components';
import { renderPicBundle } from '../lib/rpic';
import ExampleToolbar from './ExampleToolbar.astro';
import grammar from '../../../tools/highlight/rpic.tmLanguage.json';
import forestLight from '../../../tools/highlight/themes/rpic-forest-light.json';
import forestDark from '../../../tools/highlight/themes/rpic-forest-dark.json';

interface Props {
  code: string;
  circuits?: boolean;
}
const { code, circuits = false } = Astro.props;
const { svg, animations } = renderPicBundle(code, { circuits });
---

<div class="not-prose grid gap-4 mb-6 md:grid-cols-2 items-stretch">
  <div class="min-w-0 h-full flex flex-col">
    <ExampleToolbar code={code} />
    <div class="min-w-0 flex-1 [&_pre]:h-full">
      <Code code={code.trim()} lang={grammar} themes={{ light: forestLight, dark: forestDark }} />
    </div>
  </div>
  <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white relative">
    <div
      class="anim-stage grid place-items-center p-5 h-full [&_svg]:max-w-full [&_svg]:h-auto [&_svg]:overflow-visible"
      data-anims={JSON.stringify(animations)}
      set:html={svg}
    />
    <button
      class="anim-replay absolute bottom-2 right-2 text-xs font-semibold rounded-md border border-slate-200 bg-white/90 text-slate-600 px-2.5 py-1 hover:text-emerald-800 hover:border-emerald-700"
      type="button">▶ replay</button>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
  import { CustomWiggle } from 'gsap/CustomWiggle';
  import { CustomEase } from 'gsap/CustomEase';

  gsap.registerPlugin(MotionPathPlugin, MorphSVGPlugin, ScrambleTextPlugin, CustomEase, CustomWiggle);

  // Fold the optional GSAP overrides (repeat/yoyo/ease) into a tween's vars —
  // `ease` replaces the effect's default easing; repeat/yoyo loop the tween.
  // The `type` effect: reveal a label a glyph (or word) at a time — a
  // typewriter. The emitter split the label into `.rpic-ch` tspans; stagger
  // their opacity so the reveal spans the effect's duration. Mirrors the npm
  // player (bindings/js/index.js).
  function typeReveal(el: Element, a: any, tl: gsap.core.Timeline) {
    const units = el.querySelectorAll('.rpic-ch');
    if (!units.length) return;
    const step = a.duration / units.length;
    const vars = withOverrides({ opacity: 0, duration: step, stagger: step, ease: 'none' }, a);
    return a.out ? tl.to(units, vars, a.start) : tl.from(units, vars, a.start);
  }

  // The `wiggle` effect: a quick oscillating shake that returns to rest, to
  // draw the eye. Uses CustomWiggle's `wiggle(n)` ease string; rotates about the
  // element's centre and settles back to 0. Mirrors the npm player.
  function wiggleShake(el: Element, a: any, tl: gsap.core.Timeline) {
    const n = a.wiggles || 6;
    const vars = withOverrides(
      { rotation: 8, transformOrigin: '50% 50%', duration: a.duration, ease: `wiggle(${n})` },
      a
    );
    return tl.fromTo(el, { rotation: 0 }, vars, a.start);
  }

  // The `scramble` effect: glyphs cycle through random characters and resolve
  // to the real text — a decode reveal. Needs GSAP's ScrambleTextPlugin.
  // `{original}` scrambles the element's existing text; `out` scrambles away.
  // Mirrors the npm player (bindings/js/index.js).
  function scrambleReveal(el: Element, a: any, tl: gsap.core.Timeline) {
    const text = el.querySelector('text');
    if (!text) return;
    const chars = a.chars || 'upperCase';
    const target = a.out ? '' : '{original}';
    const vars = withOverrides(
      { duration: a.duration, scrambleText: { text: target, chars, speed: 1 }, ease: 'none' },
      a
    );
    return tl.to(text, vars, a.start);
  }

  function withOverrides(vars: any, a: any) {
    if (a.repeat) vars.repeat = a.repeat;
    if (a.yoyo) vars.yoyo = true;
    if (a.ease) vars.ease = a.ease;
    return vars;
  }

  const SVG_NS = 'http://www.w3.org/2000/svg';

  // Build SVG path data for the primitives rpic emits — MotionPath/MorphSVG
  // need a real <path>, not a raw <line>/<rect>/<circle>.
  function pathDataOf(el: Element): string | null {
    const n = el.tagName.toLowerCase();
    const f = (a: string) => parseFloat(el.getAttribute(a) || '0') || 0;
    if (n === 'path') return el.getAttribute('d');
    if (n === 'line') return `M${f('x1')},${f('y1')} L${f('x2')},${f('y2')}`;
    if (n === 'polyline' || n === 'polygon') {
      const nums = (el.getAttribute('points') || '').trim().split(/[\s,]+/).map(Number);
      if (nums.length < 4) return null;
      let d = '';
      for (let i = 0; i + 1 < nums.length; i += 2) d += `${i ? 'L' : 'M'}${nums[i]},${nums[i + 1]} `;
      return n === 'polygon' ? d + 'Z' : d.trim();
    }
    if (n === 'rect') return `M${f('x')},${f('y')} h${f('width')} v${f('height')} h${-f('width')} Z`;
    if (n === 'circle') {
      const r = f('r'), cx = f('cx'), cy = f('cy');
      return `M${cx - r},${cy} a${r},${r} 0 1,0 ${2 * r},0 a${r},${r} 0 1,0 ${-2 * r},0 Z`;
    }
    if (n === 'ellipse') {
      const rx = f('rx'), ry = f('ry'), cx = f('cx'), cy = f('cy');
      return `M${cx - rx},${cy} a${rx},${ry} 0 1,0 ${2 * rx},0 a${rx},${ry} 0 1,0 ${-2 * rx},0 Z`;
    }
    return null;
  }

  // Replace a primitive with an equivalent <path> in place (preserving paint).
  function convertToPath(el: Element): Element {
    if (!el || el.tagName.toLowerCase() === 'path') return el;
    const d = pathDataOf(el);
    if (!d || !el.parentNode) return el;
    const p = document.createElementNS(SVG_NS, 'path');
    p.setAttribute('d', d);
    for (const attr of Array.from(el.attributes)) {
      if (!/^(x1|y1|x2|y2|points|x|y|width|height|cx|cy|r|rx|ry)$/.test(attr.name)) {
        p.setAttribute(attr.name, attr.value);
      }
    }
    el.parentNode.replaceChild(p, el);
    return p;
  }

  // Convert every shape a move/morph references to a <path> before any tween
  // captures element refs (so a concurrent draw traces the path, not a
  // now-detached primitive).
  function preconvertGeometry(stage: HTMLElement, anims: any[]) {
    const ALL = 'path, polyline, line, rect, circle, ellipse, polygon';
    const pick = (id: string | undefined, sel: string) => {
      if (!id) return;
      const g = stage.querySelector(`[id="${id}"]`);
      const prim = g && g.querySelector(sel);
      if (prim) convertToPath(prim);
    };
    for (const a of anims) {
      if (a.effect === 'move') pick(a.path, 'path, polyline, line');
      if (a.effect === 'morph') {
        pick(a.id, ALL);
        pick(a.morph, ALL);
      }
    }
  }

  // Entrances tween FROM the hidden vars; `out` reverses into an exit (TO them).
  function enterExit(tl: gsap.core.Timeline, el: Element, vars: any, a: any) {
    return a.out ? tl.to(el, vars, a.start) : tl.from(el, vars, a.start);
  }

  // The `slide` effect: translate in (or, with `out`, away) from a compass
  // direction, offset by the element's own extent so it clears its slot.
  function slideIn(tl: gsap.core.Timeline, el: Element, a: any) {
    let bb = { width: 0, height: 0 };
    try {
      bb = (el as SVGGraphicsElement).getBBox();
    } catch {
      /* not yet laid out */
    }
    const off: any = {
      left: { x: -(bb.width * 1.5 || 40) },
      right: { x: bb.width * 1.5 || 40 },
      up: { y: -(bb.height * 1.5 || 40) },
      down: { y: bb.height * 1.5 || 40 },
    }[a.from || 'left'];
    enterExit(tl, el, withOverrides({ ...off, opacity: 0, duration: a.duration, ease: 'power2.out' }, a), a);
  }

  // The `highlight` effect: emphasise `el` — recolour + thicken its outline and
  // give the object a small scale pulse (so it reads at a glance), or a
  // colour-free scale pulse. One-directional; pair with repeat/yoyo.
  function highlightWith(el: Element, a: any, tl: gsap.core.Timeline) {
    if (a.color) {
      const shapes = el.querySelectorAll('path, polyline, line, rect, circle, ellipse, polygon');
      tl.to(
        shapes,
        withOverrides({ stroke: a.color, strokeWidth: '+=2', duration: a.duration, ease: 'power1.inOut' }, a),
        a.start
      );
      tl.to(
        el,
        withOverrides({ scale: 1.1, transformOrigin: '50% 50%', duration: a.duration, ease: 'power1.inOut' }, a),
        a.start
      );
    } else {
      tl.to(
        el,
        withOverrides({ scale: 1.12, transformOrigin: '50% 50%', duration: a.duration, ease: 'power1.inOut' }, a),
        a.start
      );
    }
  }

  // The `morph` effect: tween `el`'s outline into the shape referenced by
  // `a.morph`, via GSAP's MorphSVGPlugin.
  function morphInto(stage: HTMLElement, el: Element, a: any, tl: gsap.core.Timeline) {
    if (!a.morph) return;
    const target = stage.querySelector(`[id="${a.morph}"]`);
    // Both were converted to <path> by preconvertGeometry.
    const src = el.querySelector('path');
    const dst = target && target.querySelector('path');
    if (!src || !dst) return;
    tl.to(src, withOverrides({ morphSVG: dst, duration: a.duration, ease: 'power1.inOut' }, a), a.start);
  }

  // The `move` effect: travel `el` along the geometry referenced by `a.path`.
  function moveAlong(stage: HTMLElement, el: Element, a: any, tl: gsap.core.Timeline) {
    if (!a.path) return;
    const group = stage.querySelector(`[id="${a.path}"]`);
    // The shaft was converted to a <path>; skip the arrowhead <polygon>.
    const pathEl = group && group.querySelector('path');
    if (!pathEl) return;
    tl.to(
      el,
      withOverrides(
        {
          motionPath: { path: pathEl, align: pathEl, alignOrigin: [0.5, 0.5], autoRotate: false },
          duration: a.duration,
          ease: 'none',
        },
        a
      ),
      a.start
    );
  }

  function drawOn(group: Element, a: any, tl: gsap.core.Timeline) {
    group.querySelectorAll('path, polyline, line, rect, circle, ellipse, polygon').forEach((el) => {
      // filled, unstroked elements (arrowheads) can't be dash-traced —
      // pop them in as the shaft reaches the tip
      const fill = el.getAttribute('fill');
      if (el.getAttribute('stroke-width') === '0' || (fill && fill !== 'none' && !el.getAttribute('stroke'))) {
        tl.from(
          el,
          { opacity: 0, scale: 0, transformOrigin: '50% 50%', duration: Math.min(0.2, a.duration * 0.4), ease: 'back.out(1.7)' },
          a.start + a.duration * 0.8
        );
        return;
      }
      let len = 0;
      try {
        len = (el as SVGGeometryElement).getTotalLength();
      } catch {
        len = 0;
      }
      if (len > 0) {
        // `out` reverses the trace: the stroke retracts (dashoffset 0 → len).
        const [begin, end] = a.out ? [0, len] : [len, 0];
        tl.fromTo(
          el,
          { strokeDasharray: len, strokeDashoffset: begin },
          withOverrides({ strokeDashoffset: end, duration: a.duration, ease: 'none' }, a),
          a.start
        );
      } else {
        enterExit(tl, el, withOverrides({ opacity: 0, duration: a.duration }, a), a);
      }
    });
    // fade the labels in together as the trace nears completion — same timing
    // as the npm player (bindings/js/index.js) so the two stay in lockstep
    const texts = group.querySelectorAll('text');
    if (texts.length) {
      tl.from(texts, { opacity: 0, duration: a.duration * 0.6 }, a.start + a.duration * 0.4);
    }
  }

  // One live timeline per stage: a replay mid-animation must kill the
  // previous timeline and reset the SVG to its pristine state, otherwise two
  // timelines tween the same elements (`.from()` would capture half-animated
  // values as the "end" state and shapes jump or stick).
  const timelines = new WeakMap<HTMLElement, gsap.core.Timeline>();

  function play(stage: HTMLElement) {
    const anims = JSON.parse(stage.dataset.anims || '[]');
    timelines.get(stage)?.kill();
    gsap.set(stage.querySelectorAll('svg, svg *'), { clearProps: 'all' });
    preconvertGeometry(stage, anims);
    const tl = gsap.timeline();
    for (const a of anims) {
      const el = stage.querySelector(`[id="${a.id}"]`);
      if (!el) continue;
      switch (a.effect) {
        case 'fade':
          enterExit(tl, el, withOverrides({ opacity: 0, duration: a.duration, ease: 'power1.out' }, a), a);
          break;
        case 'pop':
          enterExit(
            tl,
            el,
            withOverrides({ scale: 0, transformOrigin: '50% 50%', duration: a.duration, ease: 'back.out(1.7)' }, a),
            a
          );
          break;
        case 'slide':
          slideIn(tl, el, a);
          break;
        case 'draw':
          drawOn(el, a, tl);
          break;
        case 'move':
          moveAlong(stage, el, a, tl);
          break;
        case 'morph':
          morphInto(stage, el, a, tl);
          break;
        case 'highlight':
          highlightWith(el, a, tl);
          break;
        case 'type':
          typeReveal(el, a, tl);
          break;
        case 'scramble':
          scrambleReveal(el, a, tl);
          break;
        case 'wiggle':
          wiggleShake(el, a, tl);
          break;
        default:
          // unknown effect: fade it in, mirroring the npm player
          // (bindings/js/index.js) so the two stay in lockstep
          enterExit(tl, el, withOverrides({ opacity: 0, duration: a.duration }, a), a);
      }
    }
    timelines.set(stage, tl);
    return tl;
  }

  document.querySelectorAll<HTMLElement>('.anim-stage').forEach((stage) => {
    const replay = stage.parentElement?.querySelector('.anim-replay');
    replay?.addEventListener('click', () => play(stage));
    // play when the example scrolls into view
    new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            play(stage);
            obs.disconnect();
          }
        }
      },
      { threshold: 0.4 }
    ).observe(stage);
  });
</script>
