---
// Live-animated example: the pic source beside the SVG, with the animate
// manifest driving a real GSAP timeline in the page — plus a replay button.
// Effects mirror the @strategicprojects/rpic web player (fade/pop/draw).
import { Code } from 'astro:components';
import { renderPicBundle } from '../lib/rpic';
import grammar from '../../../tools/highlight/rpic.tmLanguage.json';
import forestLight from '../../../tools/highlight/themes/rpic-forest-light.json';
import forestDark from '../../../tools/highlight/themes/rpic-forest-dark.json';

interface Props {
  code: string;
  circuits?: boolean;
}
const { code, circuits = false } = Astro.props;
const { svg, animations } = renderPicBundle(code, { circuits });
---

<div class="not-prose grid gap-4 mb-6 md:grid-cols-2 items-stretch">
  <div class="min-w-0 h-full [&_pre]:h-full">
    <Code code={code.trim()} lang={grammar} themes={{ light: forestLight, dark: forestDark }} />
  </div>
  <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white relative">
    <div
      class="anim-stage grid place-items-center p-5 h-full [&_svg]:max-w-full [&_svg]:h-auto [&_svg]:overflow-visible"
      data-anims={JSON.stringify(animations)}
      set:html={svg}
    />
    <button
      class="anim-replay absolute bottom-2 right-2 text-xs font-semibold rounded-md border border-slate-200 bg-white/90 text-slate-600 px-2.5 py-1 hover:text-emerald-800 hover:border-emerald-700"
      type="button">▶ replay</button>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';

  gsap.registerPlugin(MotionPathPlugin, MorphSVGPlugin);

  // Fold the optional GSAP overrides (repeat/yoyo/ease) into a tween's vars —
  // `ease` replaces the effect's default easing; repeat/yoyo loop the tween.
  function withOverrides(vars: any, a: any) {
    if (a.repeat) vars.repeat = a.repeat;
    if (a.yoyo) vars.yoyo = true;
    if (a.ease) vars.ease = a.ease;
    return vars;
  }

  // Entrances tween FROM the hidden vars; `out` reverses into an exit (TO them).
  function enterExit(tl: gsap.core.Timeline, el: Element, vars: any, a: any) {
    return a.out ? tl.to(el, vars, a.start) : tl.from(el, vars, a.start);
  }

  // The `slide` effect: translate in (or, with `out`, away) from a compass
  // direction, offset by the element's own extent so it clears its slot.
  function slideIn(tl: gsap.core.Timeline, el: Element, a: any) {
    let bb = { width: 0, height: 0 };
    try {
      bb = (el as SVGGraphicsElement).getBBox();
    } catch {
      /* not yet laid out */
    }
    const off: any = {
      left: { x: -(bb.width * 1.5 || 40) },
      right: { x: bb.width * 1.5 || 40 },
      up: { y: -(bb.height * 1.5 || 40) },
      down: { y: bb.height * 1.5 || 40 },
    }[a.from || 'left'];
    enterExit(tl, el, withOverrides({ ...off, opacity: 0, duration: a.duration, ease: 'power2.out' }, a), a);
  }

  // The `highlight` effect: emphasise `el` — tween its stroke to `a.color`,
  // or a colour-free scale pulse. One-directional; pair with repeat/yoyo.
  function highlightWith(el: Element, a: any, tl: gsap.core.Timeline) {
    if (a.color) {
      const shapes = el.querySelectorAll('path, polyline, line, rect, circle, ellipse, polygon');
      tl.to(shapes, withOverrides({ stroke: a.color, duration: a.duration, ease: 'power1.inOut' }, a), a.start);
    } else {
      tl.to(
        el,
        withOverrides({ scale: 1.12, transformOrigin: '50% 50%', duration: a.duration, ease: 'power1.inOut' }, a),
        a.start
      );
    }
  }

  // The `morph` effect: tween `el`'s outline into the shape referenced by
  // `a.morph`, via GSAP's MorphSVGPlugin.
  function morphInto(stage: HTMLElement, el: Element, a: any, tl: gsap.core.Timeline) {
    if (!a.morph) return;
    const target = stage.querySelector(`[id="${a.morph}"]`);
    const sel = 'path, polyline, line, rect, circle, ellipse, polygon';
    const src = el.querySelector(sel);
    const dst = target && target.querySelector(sel);
    if (!src || !dst) return;
    tl.to(src, withOverrides({ morphSVG: dst, duration: a.duration, ease: 'power1.inOut' }, a), a.start);
  }

  // The `move` effect: travel `el` along the geometry referenced by `a.path`.
  function moveAlong(stage: HTMLElement, el: Element, a: any, tl: gsap.core.Timeline) {
    if (!a.path) return;
    const group = stage.querySelector(`[id="${a.path}"]`);
    const pathEl = group && group.querySelector('path, polyline, line, polygon');
    if (!pathEl) return;
    tl.to(
      el,
      withOverrides(
        {
          motionPath: { path: pathEl, align: pathEl, alignOrigin: [0.5, 0.5], autoRotate: false },
          duration: a.duration,
          ease: 'none',
        },
        a
      ),
      a.start
    );
  }

  function drawOn(group: Element, a: any, tl: gsap.core.Timeline) {
    group.querySelectorAll('path, polyline, line, rect, circle, ellipse, polygon').forEach((el) => {
      // filled, unstroked elements (arrowheads) can't be dash-traced —
      // pop them in as the shaft reaches the tip
      const fill = el.getAttribute('fill');
      if (el.getAttribute('stroke-width') === '0' || (fill && fill !== 'none' && !el.getAttribute('stroke'))) {
        tl.from(
          el,
          { opacity: 0, scale: 0, transformOrigin: '50% 50%', duration: Math.min(0.2, a.duration * 0.4), ease: 'back.out(1.7)' },
          a.start + a.duration * 0.8
        );
        return;
      }
      let len = 0;
      try {
        len = (el as SVGGeometryElement).getTotalLength();
      } catch {
        len = 0;
      }
      if (len > 0) {
        // `out` reverses the trace: the stroke retracts (dashoffset 0 → len).
        const [begin, end] = a.out ? [0, len] : [len, 0];
        tl.fromTo(
          el,
          { strokeDasharray: len, strokeDashoffset: begin },
          withOverrides({ strokeDashoffset: end, duration: a.duration, ease: 'none' }, a),
          a.start
        );
      } else {
        enterExit(tl, el, withOverrides({ opacity: 0, duration: a.duration }, a), a);
      }
    });
    group.querySelectorAll('text').forEach((el) => {
      tl.from(el, { opacity: 0, duration: 0.15 }, a.start + a.duration * 0.6);
    });
  }

  // One live timeline per stage: a replay mid-animation must kill the
  // previous timeline and reset the SVG to its pristine state, otherwise two
  // timelines tween the same elements (`.from()` would capture half-animated
  // values as the "end" state and shapes jump or stick).
  const timelines = new WeakMap<HTMLElement, gsap.core.Timeline>();

  function play(stage: HTMLElement) {
    const anims = JSON.parse(stage.dataset.anims || '[]');
    timelines.get(stage)?.kill();
    gsap.set(stage.querySelectorAll('svg, svg *'), { clearProps: 'all' });
    const tl = gsap.timeline();
    for (const a of anims) {
      const el = stage.querySelector(`[id="${a.id}"]`);
      if (!el) continue;
      switch (a.effect) {
        case 'fade':
          enterExit(tl, el, withOverrides({ opacity: 0, duration: a.duration, ease: 'power1.out' }, a), a);
          break;
        case 'pop':
          enterExit(
            tl,
            el,
            withOverrides({ scale: 0, transformOrigin: '50% 50%', duration: a.duration, ease: 'back.out(1.7)' }, a),
            a
          );
          break;
        case 'slide':
          slideIn(tl, el, a);
          break;
        case 'draw':
          drawOn(el, a, tl);
          break;
        case 'move':
          moveAlong(stage, el, a, tl);
          break;
        case 'morph':
          morphInto(stage, el, a, tl);
          break;
        case 'highlight':
          highlightWith(el, a, tl);
          break;
      }
    }
    timelines.set(stage, tl);
    return tl;
  }

  document.querySelectorAll<HTMLElement>('.anim-stage').forEach((stage) => {
    const replay = stage.parentElement?.querySelector('.anim-replay');
    replay?.addEventListener('click', () => play(stage));
    // play when the example scrolls into view
    new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            play(stage);
            obs.disconnect();
          }
        }
      },
      { threshold: 0.4 }
    ).observe(stage);
  });
</script>
