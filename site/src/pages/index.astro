---
// Landing — tailwind-docs-style hero: headline, install one-liner, and the
// rpic calling card: pic source next to the SVG rendered by rpic itself.
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';
import AnimatedPic from '../components/AnimatedPic.astro';
import DrawValuesPic from '../components/DrawValuesPic.astro';
import heroPic from '../assets/hero.pic?raw';
import { renderPic } from '../lib/rpic';
import grammar from '../../../tools/highlight/rpic.tmLanguage.json';
import forestLight from '../../../tools/highlight/themes/rpic-forest-light.json';
import forestDark from '../../../tools/highlight/themes/rpic-forest-dark.json';

const heroSrc = heroPic.trim();
const heroSvg = renderPic(heroPic);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<DocsLayout title="rpic — pic pictures, reimagined in Rust">
  <div class="max-w-3xl">
    <p class="text-sm font-semibold text-emerald-800 dark:text-emerald-300 mb-3">v0.9.0 — hardened for untrusted input, richer colour</p>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-4">
      Describe the picture.<br />rpic draws it.
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-300 leading-8 mb-6">
      rpic is Brian Kernighan's <b>pic</b> picture-drawing language reimplemented in Rust —
      native SVG/PNG/PDF output, a 79-element circuit library, KaTeX-grade TeX math in labels,
      real typography (bold/italic/mono, any font &amp; size), gradients, hatch fills,
      <code class="text-base font-mono">rgb()</code>/hex colours (held in variables or computed), rotated
      labels, CSS hooks, a GSAP animation layer (enter/exit, motion, morph, typewriter, scramble,
      wiggle &amp; drag), structured diagnostics and per-object geometry for visual editors. Classic
      pic stays classic; every
      extension is opt-in — and the engine is hardened to never crash or hang on malformed or
      untrusted source.
    </p>
    <div class="flex flex-wrap items-center gap-3 mb-12">
      <a href={`${base}/docs/installation`}
        class="rounded-lg bg-emerald-800 hover:bg-emerald-700 text-white font-semibold text-sm px-5 py-2.5 no-underline">Get started</a>
      <code class="text-[13px] font-mono bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 px-3 py-2.5 rounded-lg">cargo install rpic-cli</code>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 items-stretch mb-16">
    <div class="min-w-0 h-full [&_pre]:h-full">
      <Code code={heroSrc} lang={grammar} themes={{ light: forestLight, dark: forestDark }} />
    </div>
    <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-100 grid place-items-center p-6"
      set:html={heroSvg} />
  </div>

  <div class="grid sm:grid-cols-2 gap-5 max-w-4xl">
    {[
      {
        t: 'Kernighan-first',
        d: 'Classic pic semantics with dpic as the practical oracle — 72/72 manual figures at parity.',
        icon: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
      },
      {
        t: 'Batteries included',
        d: 'SVG, PNG and PDF from one pure-Rust binary. Python, JS/WASM, R and C bindings.',
        icon: '<path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
      },
      {
        t: 'Honest extensions',
        d: 'Typography, colour, rotation, TeX math, gradients, hatch, animation, CSS hooks — each opt-in and inert when unused.',
        icon: '<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>',
      },
      {
        t: 'Built for editors',
        d: 'Per-object geometry, a fixed-canvas mode and structured diagnostics with exact spans — a stable base for visual tooling.',
        icon: '<path d="m4 4 7.07 17 2.51-7.39L21 11.07z"/>',
      },
    ].map(({ t, d, icon }) => (
      <div class="group rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/30 p-6 transition-colors hover:border-emerald-300 dark:hover:border-emerald-800/70">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 dark:bg-emerald-950/50 dark:text-emerald-300 transition-colors group-hover:bg-emerald-100 dark:group-hover:bg-emerald-900/50">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <Fragment set:html={icon} />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-900 dark:text-white mb-1.5 mt-0">{t}</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-0">{d}</p>
      </div>
    ))}
  </div>

  <div class="mt-16 max-w-4xl border-t border-slate-200 dark:border-slate-800 pt-8">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-1 mt-0">Watch it build</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-5">
      The same source, plus a few <code class="font-mono text-[13px]">animate</code> lines: rpic
      emits a GSAP timeline alongside the SVG. Scroll into view, or hit ▶ replay.
    </p>
    <AnimatedPic code={`.PS
margin = 0.2
In: box "input" fit
arrow
P: box "process" fit
arrow
Out: circle "done" rad 0.32
animate In with "slide" from left for 0.5
animate 1st arrow with "draw" for 0.4
animate P with "pop" for 0.4
animate 2nd arrow with "draw" for 0.4
animate Out with "pop" for 0.5
animate P with "highlight" to "crimson" for 0.6 after Out delay 0.3 repeat -1 yoyo
.PE`} />
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-0">
      Full palette on the{' '}
      <a class="underline decoration-slate-300 dark:decoration-slate-600 hover:text-emerald-700 dark:hover:text-emerald-300" href={`${base}/docs/extensions/animate`}>animate reference</a>.
    </p>
  </div>

  <div class="mt-16 max-w-4xl border-t border-slate-200 dark:border-slate-800 pt-8">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-1 mt-0">Draw any segment</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-5">
      The wave below is a spline drawn by rpic. <code class="font-mono text-[13px]">animate … with "draw"</code>
      traces it — and <code class="font-mono text-[13px]">from&nbsp;<i>p</i></code>/<code class="font-mono text-[13px]">to&nbsp;<i>p</i></code>
      reveal only a slice, highlighted over the full track as a fraction of the stroke. Hit <b>Next value</b> to sweep the window.
    </p>
    <DrawValuesPic />
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-0 mt-4">
      A nod to GreenSock's{' '}
      <a class="underline decoration-slate-300 dark:decoration-slate-600 hover:text-emerald-700 dark:hover:text-emerald-300" href="https://gsap.com/docs/v3/Plugins/DrawSVGPlugin/">DrawSVGPlugin</a>{' '}
      values demo, rebuilt on rpic's{' '}
      <a class="underline decoration-slate-300 dark:decoration-slate-600 hover:text-emerald-700 dark:hover:text-emerald-300" href={`${base}/docs/extensions/animate#partial-draw--reveal-a-stroke-segment`}>partial draw</a>{' '}
      — stroke fractions, no plugin.
    </p>
  </div>

  <div class="mt-16 max-w-4xl border-t border-slate-200 dark:border-slate-800 pt-6">
    <h2 class="text-sm font-semibold text-slate-900 dark:text-white mb-2">How to cite</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-6 mb-0">
      Using rpic in academic work? Cite it via its{' '}
      <a class="underline decoration-slate-300 dark:decoration-slate-600 hover:text-emerald-700 dark:hover:text-emerald-300" href="https://doi.org/10.5281/zenodo.21209915">Zenodo record</a>.
      The concept DOI <code class="font-mono text-[13px]">10.5281/zenodo.21209915</code> always
      resolves to the latest release; each version also gets its own DOI, and GitHub's
      “Cite this repository” reads the{' '}
      <a class="underline decoration-slate-300 dark:decoration-slate-600 hover:text-emerald-700 dark:hover:text-emerald-300" href="https://github.com/milkway/rpic-lang/blob/main/CITATION.cff">CITATION.cff</a>{' '}
      for BibTeX and APA.
    </p>
  </div>
</DocsLayout>
