    { "scope": "markup.italic.math.rpic", "settings": { "foreground": "#7a5230", "fontStyle": "italic" } },
    { "scope": "support.function.tex.rpic", "settings": { "foreground": "#5e412f", "fontStyle": "bold italic" } },
    { "scope": "constant.numeric.rpic", "settings": { "foreground": "#827717" } },
    { "scope": "constant.language.ordinal.rpic", "settings": { "foreground": "#558b2f", "fontStyle": "italic" } },
    { "scope": "variable.language.corner.rpic", "settings": { "foreground": "#00796b" } },
    { "scope": "keyword.operator.arrowhead.rpic", "settings": { "foreground": "#2e7d32", "fontStyle": "bold" } },
    { "scope": "keyword.operator.rpic", "settings": { "foreground": "#546e5a" } }
  ]
