P[185]: (0.54031,3.98255)
n=186
P[n]:P[0]

  scalefact = 1/2

define embellish {
  wheelrad = $1
  holerad = $2
  DP: (P[0]-P[n-1])*scalefact; ddist = sqrt(DP.x^2+DP.y^2)
  X: P[0]*scalefact + (-DP.y,DP.x)/ddist*wheelrad + (holerad,0)
  spline 0.55 from X to X $4
  dist = 0
  turns = $3
  for i=0 to n*turns-1 do {
    ii = pmod(i,n)+1
    DP: (P[ii]-P[ii-1])*scalefact
    ddist = sqrt(DP.x^2+DP.y^2)
    dist += ddist
    wheelangle = dist/wheelrad
    continue to P[ii]*scalefact + (-DP.y,DP.x)/ddist*wheelrad \
     + (cos(wheelangle),sin(wheelangle))*holerad
    }
  }

embellish(0.2, 0.2*5/6, 40, outlined "rgb(230,204,179)")
embellish(0.2, 0.2/3,   20, outlined "rgb(179,77,242)")

.PE
