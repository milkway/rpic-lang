define include {}
define cct_init {}
dimen_ = 0.1
define right_ {right}
define left_ {left}
define up_ {up}
define down_ {down}
.PS
include(libcct.m4)
cct_init
linethick=linethick*(1.5)
dimen_=dimen_
O:(0,0)
X:line -> from O-(.25*dimen_,0) right_ 5*dimen_; "$t$" below;
Y:line -> from O-(0,.25*dimen_) up_ 3*dimen_; "$f(t)$" rjust;
O2:O-(1.5*dimen_,0);
L1:line from O2+(2.5*dimen_,0) up_ 1/(2.5*dimen_)^2 then left_ dimen_/2 then down_ 1/(2.5*dimen_)^2 then right_ dimen_/2; "$2$" below;
L2:line from O2+(3*dimen_,0) up_ 1/(3*dimen_)^2 then left_ dimen_/2 then down_ 1/(3*dimen_)^2 then right_ dimen_/2; "$3$" below;
L3:line from O2+(3.5*dimen_,0) up_ 1/(3.5*dimen_)^2 then left_ dimen_/2 then down_ 1/(3.5*dimen_)^2 then right_ dimen_/2; "$4$" below;
L4:line from O2+(5*dimen_,0) up_ 1/(5*dimen_)^2 then left_ dimen_/2 then down_ 1/(5*dimen_)^2 then right_ dimen_/2; "$N$" below;
L5:line dotted from O2+(2*dimen_, 1/(2*dimen_)^2) down_ 1/(2*dimen_)^2; "$1$" below;
move to L5.start + (dimen_/4,dimen_/3); "$\leftarrow \frac{1}{t^2}$"
#move to L4.start - (dimen_/2,0); "$n-1$" below
"$\cdots$" at O2+(4*dimen_,(1/(4*dimen_)^2)/2)
"$\cdots$" at O2+(4*dimen_,0) below
for i=1.75*dimen_ to 6*dimen_ by 0.01 do {
line from O2+(i,1/(i^2)) to O2+(i+0.01,1/((i+.01))^2)}
.PE
