define include {}
define cct_init {}
dimen_ = 0.1
define right_ {right}
define left_ {left}
define up_ {up}
define down_ {down}
.PS
include(libcct.m4)
cct_init
linethick=linethick*(1.5)
dimen_=dimen_
O:(0,0)
X:line -> from O-(2.5*dimen_,0) right_ 5*dimen_; "$\omega$" below;
Y:line -> from O-(0,.5*dimen_) up_ 3*dimen_; "$F_1(\omega)$" rjust;
L1:line from O-(2*dimen_,0) to O+(-dimen_,1.5*dimen_) then to O then to O+(dimen_,1.5*dimen_) then to O+(2*dimen_,0);
"${\scriptsize 2\omega_0}$" at L1.end below
"${\scriptsize \omega_0}$" at O+(dimen_,0) below
"${\scriptsize -\omega_0}$" at O+(-dimen_,0) below
"${\scriptsize -2\omega_0}$" at O-(2*dimen_,0) below
"${\scriptsize 0}$" at O below rjust
"${\scriptsize A}$" at O+(0,1.5*dimen_) rjust
.PE
