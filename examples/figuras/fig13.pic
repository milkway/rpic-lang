define include {}
define cct_init {}
dimen_ = 0.1
define right_ {right}
define left_ {left}
define up_ {up}
define down_ {down}
.PS
include(libcct.m4)
cct_init
linethick=linethick*(1.5)
dimen_=dimen_
O:(0,0); "${\scriptsize 0}$" below rjust
X:line -> from O-(.25*dimen_,0) right_ 4.5*dimen_; "$t$" below;
Y:line -> from O-(0,1*dimen_) up_ 2.5*dimen_; "$f_2(t)$" rjust;
L1:line from O+(0,-.75*dimen_) right_ 1*dimen_ then up_ 1.5*dimen_ then right_ .5*dimen_ then down_ 1.5*dimen_ then right_ .5*dimen_ then up_ 1.5*dimen_ then right_ 1.5*dimen_ then down_ .75*dimen_
"${\scriptsize 3}$" at O+(1.5*dimen_,0) below rjust
"${\scriptsize 4}$" at O+(2*dimen_,0) below rjust
"${\scriptsize 2}$" at O+(1*dimen_,0) below rjust
"${\scriptsize 7}$" at O+(3.5*dimen_,0) below rjust
.PE
