define include {}
define cct_init {}
dimen_ = 0.1
define right_ {right}
define left_ {left}
define up_ {up}
define down_ {down}
.PS
include(libcct.m4)
cct_init
linethick=linethick*(1.5)
T1:circle radius .15; "$a_1$" at T1.c;
X2:line -> "$w_{1}$" above from T1.e right_ dimen_*1.5;
T:circle radius dimen_/2 with .w at X2.end; "$\sum$" at T.c
T2:circle radius .15 with .c at T1.c + (0,1*dimen_); "$1$" at T2.c;
X1:line -> "$w_{0}$" above from T2.e to T.nw;
T3:circle radius .15 with .c at T1.c - (0,1*dimen_); "$a_2$" at T3.c;
X1:line -> "$w_{2}$" above from T3.e to T.sw;
Y:line -> from T.e right_ dimen_*1
B:box
L:line from (B.sw + (.1,.1)) right_ to (B.c.x,B.s.y+.1) then up_ to B.n - (0,.1) then right_ to B.ne - (.1,.1)
.PE
