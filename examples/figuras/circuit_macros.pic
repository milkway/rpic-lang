# circuit_macros direction+length compatibility layer for rpic.
#
# circuit_macros (J. D. Aplevich) draws elements along a `direction length`
# argument (e.g. `resistor(up_ dimen_)`), advancing the pen, with named
# terminals. rpic's native library (load with -c) draws the same elements
# between two points (`resistor(A, B)`). This shim adapts the former to the
# latter, REUSING the native element geometry: each element draws an invisible
# spine along `$1` (giving .start/.end and advancing the pen) and then calls the
# native two-point geometry (`__resistor`, …). Load native first (`rpic -c`),
# then this file.

define include {}              # m4 include() — no-op
define cct_init {}             # circuit_macros setup — no-op
dimen_ = 0.4                   # default element length
elen_ = dimen_                 # circuit_macros element length alias
define right_ {right}
define left_ {left}
define up_ {up}
define down_ {down}
define ljust_ {ljust}          # label justification (issue #180)
define rjust_ {rjust}

# linear elements: invisible spine + reuse of the native two-point geometry
define resistor  { line invis $1; __resistor(last line.start, last line.end) }
define capacitor { line invis $1; __capacitor(last line.start, last line.end) }
define inductor  { line invis $1; __inductor(last line.start, last line.end) }
define diode     { line invis $1; __diode(last line.start, last line.end) }

# element box (generic impedance): a block so `Z1: ebox(...)` exposes the box
# corners (Z1.e/.w/.n/.s) via the block's bounds, while the invisible spine
# advances the pen so consecutive eboxes chain.
define ebox { [ line invis $1; __ebox(last line.start, last line.end) ] }

# current source (`source(dir len, I)`); the type arg is ignored — drawn as a
# current source (circle + internal arrow).
define source { line invis $1; __isource(last line.start, last line.end) }

# a connecting line (crossover hops not modelled — drawn as a plain line)
define crossover { line $1 }

# ground at the current point, pointing down (`ground` or `ground(,type)`)
define ground { __ground(Here) }

# a junction dot: bare `dot` (at Here), `dot(at P)`, or `dot at P` all work —
# the optional argument / trailing modifier flows straight onto the circle.
define dot { circle rad 0.04 fill 0 $1 }

# bipolar transistor: a block exposing .B/.E/.C terminals, reusing the native
# sign-parameterized geometry (__bjt). $1 direction (up_/down_), $2 R = reflect
# horizontally, $3 P = PNP. The block lets `Q1: bi_tr(...)` carry Q1.B/.E/.C.
define bi_tr { [ bpnp = 0; if "$3" == "P" then { bpnp = 1 }; bsx = 1; bsy = 1; if "$2" == "R" then { bsx = 0 - 1 }; if "$1" == "down_" then { bsy = 0 - 1; bsx = 0 - bsx }; __bjt((0,0), bsx, bsy, bpnp); B:(gBase_x,gBase_y); C:(gColl_x,gColl_y); E:(gEmit_x,gEmit_y) ] }

# op-amp: a block exposing .In1/.In2/.Out, reusing the native sign-parameterized
# geometry (__opamp). An invisible spine along $1 detects the orientation
# (right_ → inputs left, left_ → inputs right). Optional +/- label args ignored.
define opamp { [ line invis $1; oosx = 1; if (last line.end.x - last line.start.x) < 0 then { oosx = 0 - 1 }; __opamp((0,0), oosx); In1:(gIm_x,gIm_y); In2:(gIp_x,gIp_y); Out:(gY_x,gY_y) ] }

# element labels (right/left/below the centre of the last drawn object). Using
# untyped `last` (not `last line`) lets a label follow any element — including a
# `dot` (circle) — not just a line.
define rlabel { "$2" at last.c + (dimen_/3, 0) ljust }
define llabel { "$2" at last.c - (dimen_/3, 0) rjust }
define dlabel { "$2" at last.c below }

# dimension annotation (libgen.m4): `dimension_(linespec, offset, label, tick)`.
# Draws witness lines from the two endpoints of `linespec`, a double-headed
# dimension line parallel to it at perpendicular distance `offset`, and `label`
# at the midpoint. `tick` sizes the small gap past the dimension line.
define __dimension {
  dmsx=$1.x; dmsy=$1.y; dmex=$2.x; dmey=$2.y; dmoff=$3
  dmtl = 0.1
  dmdx=dmex-dmsx; dmdy=dmey-dmsy; dmL=sqrt(dmdx*dmdx+dmdy*dmdy)
  dmpx=0-dmdy/dmL; dmpy=dmdx/dmL
  line from (dmsx,dmsy) to (dmsx+dmpx*(dmoff+dmtl),dmsy+dmpy*(dmoff+dmtl))
  line from (dmex,dmey) to (dmex+dmpx*(dmoff+dmtl),dmey+dmpy*(dmoff+dmtl))
  dmax=dmsx+dmpx*dmoff; dmay=dmsy+dmpy*dmoff; dmbx=dmex+dmpx*dmoff; dmby=dmey+dmpy*dmoff
  # circuit_macros semantics: a non-empty 4th arg is the label width — the
  # dimension line breaks around a central gap and the label sits inside it.
  if "$4" == "" then { line <- -> from (dmax,dmay) to (dmbx,dmby) } else { dmgap=$4; dmux=dmdx/dmL; dmuy=dmdy/dmL; dmcx=(dmax+dmbx)/2; dmcy=(dmay+dmby)/2; line <- from (dmax,dmay) to (dmcx-dmux*dmgap/2,dmcy-dmuy*dmgap/2); line -> from (dmcx+dmux*dmgap/2,dmcy+dmuy*dmgap/2) to (dmbx,dmby) }
  gDim_x=(dmsx+dmex)/2+dmpx*dmoff; gDim_y=(dmsy+dmey)/2+dmpy*dmoff
}
define dimension_ {
  line invis $1
  __dimension(last line.start, last line.end, $2, $4)
  "$3" at (gDim_x, gDim_y)
}
