# Easing curves, drawn by rpic itself — a static "ease visualiser" in pic.
# Each cell plots input time (x, 0->1) against eased progress (y, 0->1) by
# sampling a GSAP ease formula in a `for` loop and joining the points; the
# dashed diagonal is the linear (no-ease) reference. Overshooting eases
# (back/elastic) and the bounce leave the unit box on purpose — `margin`
# reserves room for those excursions and the labels.
.PS
margin = 0.12
u = 1.0            # cell size (inches)
gx = 0.55          # horizontal gap between cells
gy = 0.72          # vertical gap between rows
n = 48             # samples per curve
pi = 3.14159265358979
ln2 = 0.69314718056

# frame(ox, oy): unit box + faint linear-reference diagonal at that origin.
# `colored` fills a box, so use `outlined` to keep the cell white.
define frame {
  box wid u ht u thick 0.7 outlined 0xcbd5e1 with .sw at ($1,$2)
  line from ($1,$2) to ($1+u,$2+u) dashed thick 0.6 colored 0xcbd5e1
}

# --- row 0 : polynomial ramps (power1=quad, power2=cubic, power4=quint) ---
oy = 0
ox = 0*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=1-(1-t)^2; b=1-(1-s)^2
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"power1.out" at (ox+u/2, oy-0.2)

ox = 1*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=1-(1-t)^3; b=1-(1-s)^3
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"power2.out" at (ox+u/2, oy-0.2)

ox = 2*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=1-(1-t)^5; b=1-(1-s)^5
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"power4.out" at (ox+u/2, oy-0.2)

# --- row 1 : sine / expo / circ ---
oy = -(u+gy)
ox = 0*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=sin(t*pi/2); b=sin(s*pi/2)
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"sine.out" at (ox+u/2, oy-0.2)

ox = 1*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=1-exp(-10*t*ln2); b=1-exp(-10*s*ln2)
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"expo.out" at (ox+u/2, oy-0.2)

ox = 2*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=sqrt(1-(t-1)^2); b=sqrt(1-(s-1)^2)
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"circ.out" at (ox+u/2, oy-0.2)

# --- row 2 : back / elastic / bounce (overshoot + wobble + bounce) ---
oy = -2*(u+gy)
k = 1.70158
ox = 0*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=1+(k+1)*(t-1)^3+k*(t-1)^2; b=1+(k+1)*(s-1)^3+k*(s-1)^2
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"back.out" at (ox+u/2, oy-0.2)

p = 0.3
ox = 1*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  a=exp(-10*t*ln2)*sin((t-p/4)*2*pi/p)+1
  b=exp(-10*s*ln2)*sin((s-p/4)*2*pi/p)+1
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"elastic.out" at (ox+u/2, oy-0.2)

ox = 2*(u+gx);  frame(ox,oy)
for i=0 to n-1 do { t=i/n; s=(i+1)/n
  if t < 0.363636 then { a=7.5625*t^2 } else {
  if t < 0.727273 then { a=7.5625*(t-0.545455)^2+0.75 } else {
  if t < 0.909091 then { a=7.5625*(t-0.818182)^2+0.9375 } else {
                         a=7.5625*(t-0.954545)^2+0.984375 } } }
  if s < 0.363636 then { b=7.5625*s^2 } else {
  if s < 0.727273 then { b=7.5625*(s-0.545455)^2+0.75 } else {
  if s < 0.909091 then { b=7.5625*(s-0.818182)^2+0.9375 } else {
                         b=7.5625*(s-0.954545)^2+0.984375 } } }
  line from (ox+u*t,oy+u*a) to (ox+u*s,oy+u*b) thick 1.6 colored 0x2f855a }
"bounce.out" at (ox+u/2, oy-0.2)
.PE
